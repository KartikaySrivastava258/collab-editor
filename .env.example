# Copy this file to .env and fill in your values.
# The server starts without LLM_API_KEY — the AI agent runs in demo mode.

# Go server port (default: 8080)
PORT=8080

# OpenAI-compatible API key — enables the AI writing agent
# Supports: OpenAI, Azure OpenAI, Ollama, Groq, Together AI, etc.
LLM_API_KEY=

# API base URL (default: OpenAI)
LLM_API_URL=https://api.openai.com/v1

# React frontend WebSocket URL (used during development)
REACT_APP_SERVER_URL=ws://localhost:8080/ws
